#!/usr/bin/env python3
"""
CCFTS skill file validator v0.2 — checks YAML frontmatter, cross-references,
slug patterns, SLOT contracts, intelligence references, and structure.
"""

import os
import sys
from pathlib import Path

SKILLS_DIR = Path(__file__).resolve().parent.parent / "skills"

# ── Controlled vocabularies ─────────────────────────────────────
ALLOWED_CATEGORIES = {"foundation", "financial-reporting", "accounting", "tax", "analysis", "management", "intelligence"}
ALLOWED_DOMAINS = {"fr", "acct", "tax", "anlys", "mgmt", "intel", "foundation"}
ALLOWED_LEVELS = {"soe-group", "subsidiary", "branch", "project-unit", "spv", "all", "enterprise", "small-enterprise", "intl", "investment-company", "construction-epc"}  # legacy aliases included; enterprise/small-enterprise/intl added Phase 2.5
ALLOWED_QUALITY_TIERS = {"research-verified", "accountant-verified"}
ALLOWED_ENTERPRISE_SCALES = {"large-soe", "medium", "small"}
ALLOWED_AUTHORITIES = {"SASAC", "MOF", "STA", "MOHURD"}
SKIP_FILES = {"README.md", "_template-skill.md"}

# Required frontmatter fields per category
REQUIRED_FIELDS = {
    "foundation": ["name", "description", "version", "jurisdiction", "category", "quality_tier", "verified_by"],
    "financial-reporting": ["name", "description", "version", "jurisdiction", "category", "quality_tier", "verified_by", "entity_levels", "domains"],
    "accounting": ["name", "description", "version", "jurisdiction", "category", "quality_tier", "verified_by", "entity_levels", "domains"],
    "tax": ["name", "description", "version", "jurisdiction", "category", "quality_tier", "verified_by", "entity_levels", "domains"],
    "analysis": ["name", "description", "version", "jurisdiction", "category", "quality_tier", "verified_by", "entity_levels", "domains"],
    "management": ["name", "description", "version", "jurisdiction", "category", "quality_tier", "verified_by", "entity_levels", "domains"],
    "intelligence": ["name", "description", "version", "jurisdiction", "category", "quality_tier", "verified_by", "authority", "effective_date", "sources"],
}

# Fields that can be lists in frontmatter
LIST_FIELDS = {"depends_on", "entity_types", "entity_levels", "domains", "enterprise_scales", "triggers", "references", "slots", "sources"}


def parse_frontmatter(filepath: Path) -> dict | None:
    """Parse YAML frontmatter between --- delimiters, including multi-line lists."""
    text = filepath.read_text(encoding="utf-8")
    if not text.startswith("---"):
        return None
    end = text.find("---", 3)
    if end == -1:
        return None
    fm_text = text[3:end].strip()
    result = {}
    current_list_key = None
    current_list_values = []
    for line in fm_text.splitlines():
        line_stripped = line.strip()
        # Multi-line list continuation (YAML: "  - value")
        if current_list_key and line_stripped.startswith("- "):
            val = line_stripped[2:].strip().strip('"').strip("'")
            current_list_values.append(val)
            continue
        # End of list — save and reset
        if current_list_key and not line_stripped.startswith("- "):
            result[current_list_key] = current_list_values
            current_list_key = None
            current_list_values = []
        if ":" not in line_stripped:
            continue
        key, _, value = line_stripped.partition(":")
        key = key.strip()
        value = value.strip().strip('"').strip("'").strip()
        # Start of a new list (value is empty, list items follow on indented lines)
        if not value and key in LIST_FIELDS:
            current_list_key = key
            current_list_values = []
            continue
        if key in LIST_FIELDS:
            val = value.strip("[]")
            result[key] = [v.strip().strip('"').strip("'") for v in val.split(",") if v.strip()] if val else []
        elif key in ("jurisdiction",):
            result[key] = value
        elif key in ("is_base",):
            result[key] = value.lower() == "true"
        else:
            result[key] = value
    # Save any trailing list
    if current_list_key and current_list_values:
        result[current_list_key] = current_list_values
    return result


def check_slug_pattern(name: str, relpath: str) -> list[str]:
    """Validate slug follows ccfts-{domain}-{level}-{topic} or ccfts-{topic} for foundation/intel."""
    issues = []
    # Foundation files: ccfts-workflow-base etc.
    if relpath.startswith("foundation/") or relpath.startswith("intelligence/") or relpath.startswith("china-construction/") or relpath.startswith("templates/"):
        if not name.startswith("ccfts-"):
            issues.append(f"{relpath}: slug '{name}' must start with 'ccfts-'")
        return issues
    # Standard pattern: ccfts-{domain}-{level}-{topic}
    if not name.startswith("ccfts-"):
        issues.append(f"{relpath}: slug '{name}' must follow pattern ccfts-{{domain}}-{{level}}-{{topic}}")
        return issues
    parts = name.split("-")
    if len(parts) < 3:
        issues.append(f"{relpath}: slug '{name}' too short; expected ccfts-{{domain}}-{{level}}-{{topic}}")
        return issues
    domain = parts[1]  # e.g., "fr" from "ccfts-fr-project-unit-quick-report"
    # Try increasingly longer level matches (handles multi-segment levels like "project-unit", "soe-group")
    level = parts[2]
    for i in range(3, len(parts) - 1):  # leave at least one segment for topic
        if level in ALLOWED_LEVELS:
            break
        level = f"{level}-{parts[i]}"
    # 'all' files: ccfts-fr-all-rounding-rules
    if domain not in ALLOWED_DOMAINS:
        issues.append(f"{relpath}: unknown domain '{domain}' in slug '{name}'. Allowed: {ALLOWED_DOMAINS}")
    if level not in ALLOWED_LEVELS:
        issues.append(f"{relpath}: unknown level '{level}' in slug '{name}'. Allowed: {ALLOWED_LEVELS}")
    # Check file lives in correct directory
    domain_map = {"fr": "financial-reporting", "acct": "accounting", "tax": "tax", "anlys": "analysis", "mgmt": "management", "intel": "intelligence"}
    expected_dir = domain_map.get(domain)
    if expected_dir and not relpath.startswith(f"{expected_dir}/"):
        issues.append(f"{relpath}: slug domain is '{domain}' but file not in '{expected_dir}/' directory")
    return issues


def check_file(filepath: Path) -> list[str]:
    """Validate a single skill file."""
    issues = []
    relpath = str(filepath.relative_to(SKILLS_DIR))

    if filepath.name in SKIP_FILES:
        return issues
    if filepath.suffix != ".md":
        issues.append(f"{relpath}: not a .md file")
        return issues

    fm = parse_frontmatter(filepath)
    if fm is None:
        issues.append(f"{relpath}: missing or malformed YAML frontmatter")
        return issues

    name = fm.get("name", "")
    category = fm.get("category", "")

    # Required fields
    required = REQUIRED_FIELDS.get(category, REQUIRED_FIELDS["foundation"])
    for field in required:
        if field not in fm or not fm[field]:
            issues.append(f"{relpath}: missing required field '{field}'")

    if not issues:
        print(f"  OK  {relpath} ({name})")

    # Controlled vocabularies
    if "category" in fm and fm["category"] not in ALLOWED_CATEGORIES:
        issues.append(f"{relpath}: unknown category '{fm['category']}'")
    if "quality_tier" in fm and fm["quality_tier"] not in ALLOWED_QUALITY_TIERS:
        issues.append(f"{relpath}: unknown quality_tier '{fm['quality_tier']}'")
    if "jurisdiction" in fm and fm["jurisdiction"] not in ("CN", "GLOBAL"):
        issues.append(f"{relpath}: unexpected jurisdiction '{fm['jurisdiction']}'")

    # Entity levels validation
    for el in fm.get("entity_levels", []):
        if el.strip() not in ALLOWED_LEVELS:
            issues.append(f"{relpath}: unknown entity_level '{el}'")
    for es in fm.get("enterprise_scales", []):
        if es.strip() not in ALLOWED_ENTERPRISE_SCALES:
            issues.append(f"{relpath}: unknown enterprise_scale '{es}'")

    # Intelligence-specific
    if category == "intelligence":
        if "authority" in fm and fm["authority"] not in ALLOWED_AUTHORITIES:
            issues.append(f"{relpath}: unknown authority '{fm['authority']}'")
        if "sources" not in fm or not fm["sources"]:
            issues.append(f"{relpath}: intelligence skill missing 'sources' citations")

    # Slug pattern
    if name:
        issues.extend(check_slug_pattern(name, relpath))

    # is_base / fills_slots_for contract
    fills = fm.get("fills_slots_for")
    if isinstance(fills, str) and fills.lower() in ("null", "none", ""):
        fills = None
    if fm.get("is_base") and fills:
        issues.append(f"{relpath}: cannot be both 'is_base' and 'fills_slots_for'")
    if not fm.get("is_base") and "slots" in fm and fm["slots"]:
        issues.append(f"{relpath}: only base skills should define 'slots'")

    # Backward compat: entity_types (deprecated) → entity_levels
    if fm.get("entity_types") and not fm.get("entity_levels"):
        issues.append(f"{relpath}: using deprecated 'entity_types'; use 'entity_levels' instead")

    return issues


def check_cross_references(all_files: list[Path], skippable_slugs: set) -> list[str]:
    """Verify depends_on and references resolve to existing slugs."""
    issues = []
    all_slugs = set()
    for fp in all_files:
        fm = parse_frontmatter(fp)
        if fm and "name" in fm:
            all_slugs.add(fm["name"])
    all_slugs.update(skippable_slugs)

    for fp in all_files:
        fm = parse_frontmatter(fp)
        if not fm:
            continue
        relpath = str(fp.relative_to(SKILLS_DIR))
        for field in ("depends_on", "references"):
            deps = fm.get(field, [])
            if isinstance(deps, str):
                deps = [deps]
            for dep in deps:
                dep = dep.strip()
                # Skip null/future slugs
                if not dep or dep == "null":
                    continue
                if dep not in all_slugs:
                    issues.append(f"{relpath}: {field} '{dep}' not found in any skill file")

    print(f"\n  Cross-references: {len(all_slugs)} known slugs, all references checked")
    return issues


def main():
    if not SKILLS_DIR.exists():
        print(f"ERROR: skills directory not found at {SKILLS_DIR}")
        sys.exit(1)

    all_files = [p for p in sorted(SKILLS_DIR.rglob("*.md")) if p.name not in SKIP_FILES]
    print(f"\nCCFTS Skill Validator v0.2 — {len(all_files)} files\n")

    # Collect skippable future slugs
    skippable_slugs = set()
    for fp in all_files:
        fm = parse_frontmatter(fp)
        if fm and "fills_slots_for" in fm and fm["fills_slots_for"]:
            skippable_slugs.add(fm["fills_slots_for"])

    all_issues = []
    for fp in all_files:
        all_issues.extend(check_file(fp))
    all_issues.extend(check_cross_references(all_files, skippable_slugs))

    if all_issues:
        print(f"\nFAILED: {len(all_issues)} issue(s)\n")
        for issue in all_issues:
            print(f"  ✗ {issue}")
        sys.exit(1)
    else:
        print(f"\nPASSED: {len(all_files)} files, 0 issues.")
        sys.exit(0)


if __name__ == "__main__":
    main()
