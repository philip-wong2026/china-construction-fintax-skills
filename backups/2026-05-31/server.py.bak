_SKILLS_ROOT = os.environ.get("CCFTS_ROOT")
if not _SKILLS_ROOT:
    _SKILLS_ROOT = Path(__file__).resolve().parent.parent.parent / "skills"
else:
    _SKILLS_ROOT = Path(_SKILLS_ROOT)

MAX_FILE_SIZE = 2 * 1024 * 1024  # 2 MB

